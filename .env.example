# Copy to .env and fill in values

# App image name (used by docker compose)
APP_IMAGE=walmart-graphrag:latest

# Neo4j
NEO4J_PASSWORD=graphrag_password

# OpenAI (leave blank to use Ollama only)
OPENAI_API_KEY=

# Ollama model overrides (defaults shown)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2
OPENAI_MODEL=gpt-4o-mini

# Kaggle (for data download)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Tuning (defaults shown)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SIMILARITY_THRESHOLD=0.85
